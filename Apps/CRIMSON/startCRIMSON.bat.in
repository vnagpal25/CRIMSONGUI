@echo off
setlocal
pushd "%~dp0"
set "QT_DEBUG_PLUGINS="
set "CRIMSON_RUNTIME_PATH=@CMAKE_RUNTIME_OUTPUT_DIRECTORY@\@VS_BUILD_TYPE@;@CMAKE_RUNTIME_OUTPUT_DIRECTORY@\plugins\@VS_BUILD_TYPE@;@MITK_RUNTIME_PATH@"
if not "@OCC_RUNTIME_PATH@" == "" set "CRIMSON_RUNTIME_PATH=%CRIMSON_RUNTIME_PATH%;@OCC_RUNTIME_PATH@"
if not "@QtPropertyBrowser_RUNTIME_LIBRARY_DIRS@" == "" set "CRIMSON_RUNTIME_PATH=%CRIMSON_RUNTIME_PATH%;@QtPropertyBrowser_RUNTIME_LIBRARY_DIRS@\@VS_BUILD_TYPE@"
if not "@CRIMSON_VCPKG_RUNTIME_PATH@" == "" set "CRIMSON_RUNTIME_PATH=%CRIMSON_RUNTIME_PATH%;@CRIMSON_VCPKG_RUNTIME_PATH@"
if not "@CUSTOM_RUNTIME_PATH@" == "" set "CRIMSON_RUNTIME_PATH=%CRIMSON_RUNTIME_PATH%;@CUSTOM_RUNTIME_PATH@"
set "PATH=%CRIMSON_RUNTIME_PATH%;%PATH%"
IF NOT [%1] == [EnvOnly] @VS_BUILD_TYPE@\@MY_APP_NAME@.exe
popd
