@echo off
set "PATH=@MITK_RUNTIME_PATH@;%PATH%"
if not "@OCC_RUNTIME_PATH@" == "" set "PATH=@OCC_RUNTIME_PATH@;%PATH%"
if not "@CRIMSON_VCPKG_RUNTIME_PATH@" == "" set "PATH=@CRIMSON_VCPKG_RUNTIME_PATH@;%PATH%"
if not "@CUSTOM_RUNTIME_PATH@" == "" set "PATH=@CUSTOM_RUNTIME_PATH@;%PATH%"
if not "@QtPropertyBrowser_RUNTIME_LIBRARY_DIRS@" == "" set "PATH=@QtPropertyBrowser_RUNTIME_LIBRARY_DIRS@\@VS_BUILD_TYPE@;%PATH%"
set "PATH=@CMAKE_RUNTIME_OUTPUT_DIRECTORY@\plugins\@VS_BUILD_TYPE@;@CMAKE_RUNTIME_OUTPUT_DIRECTORY@\@VS_BUILD_TYPE@;%PATH%"
IF NOT [%1] == [EnvOnly] @VS_BUILD_TYPE@\@MY_APP_NAME@.exe
